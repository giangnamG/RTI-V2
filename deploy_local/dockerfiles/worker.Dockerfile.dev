FROM python:3.13-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl wget unzip \
    nmap whatweb \
    openssl bc xxd bsdmainutils dnsutils procps \
    && rm -rf /var/lib/apt/lists/*

# ── ProjectDiscovery tools + testssl.sh + nikto ──────────────
ARG PD_SUBFINDER=v2.6.6
ARG PD_HTTPX=v1.6.10
ARG PD_NUCLEI=v3.7.0
ARG PD_NAABU=v2.3.1
ARG PD_KATANA=v1.1.2
ARG PD_FFUF=v2.1.0
ARG TESTSSL_BRANCH=3.2

RUN set -eux; \
    # subfinder
    wget -q "https://github.com/projectdiscovery/subfinder/releases/download/${PD_SUBFINDER}/subfinder_${PD_SUBFINDER#v}_linux_amd64.zip" -O /tmp/sf.zip \
    && unzip -q /tmp/sf.zip subfinder -d /usr/local/bin && chmod +x /usr/local/bin/subfinder && rm /tmp/sf.zip; \
    # httpx
    wget -q "https://github.com/projectdiscovery/httpx/releases/download/${PD_HTTPX}/httpx_${PD_HTTPX#v}_linux_amd64.zip" -O /tmp/hx.zip \
    && unzip -q /tmp/hx.zip httpx -d /usr/local/bin && chmod +x /usr/local/bin/httpx && rm /tmp/hx.zip; \
    # nuclei
    wget -q "https://github.com/projectdiscovery/nuclei/releases/download/${PD_NUCLEI}/nuclei_${PD_NUCLEI#v}_linux_amd64.zip" -O /tmp/nc.zip \
    && unzip -q /tmp/nc.zip nuclei -d /usr/local/bin && chmod +x /usr/local/bin/nuclei && rm /tmp/nc.zip; \
    # naabu
    wget -q "https://github.com/projectdiscovery/naabu/releases/download/${PD_NAABU}/naabu_${PD_NAABU#v}_linux_amd64.zip" -O /tmp/nb.zip \
    && unzip -q /tmp/nb.zip naabu -d /usr/local/bin && chmod +x /usr/local/bin/naabu && rm /tmp/nb.zip; \
    # katana
    wget -q "https://github.com/projectdiscovery/katana/releases/download/${PD_KATANA}/katana_${PD_KATANA#v}_linux_amd64.zip" -O /tmp/kt.zip \
    && unzip -q /tmp/kt.zip katana -d /usr/local/bin && chmod +x /usr/local/bin/katana && rm /tmp/kt.zip; \
    # ffuf
    wget -q "https://github.com/ffuf/ffuf/releases/download/${PD_FFUF}/ffuf_${PD_FFUF#v}_linux_amd64.tar.gz" -O /tmp/ffuf.tar.gz \
    && tar -xzf /tmp/ffuf.tar.gz -C /usr/local/bin ffuf && chmod +x /usr/local/bin/ffuf && rm /tmp/ffuf.tar.gz; \
    # testssl.sh — repo moved testssl/testssl.sh, dùng branch thay tag
    wget -q "https://github.com/testssl/testssl.sh/archive/refs/heads/${TESTSSL_BRANCH}.tar.gz" -O /tmp/testssl.tar.gz \
    && mkdir -p /opt/testssl \
    && tar -xzf /tmp/testssl.tar.gz -C /opt/testssl --strip-components=1 \
    && chmod +x /opt/testssl/testssl.sh \
    && ln -sf /opt/testssl/testssl.sh /usr/local/bin/testssl.sh \
    && rm /tmp/testssl.tar.gz

# ── Nuclei: update binary rồi update templates ───────────────
RUN nuclei -update -silent 2>/dev/null || true
RUN nuclei -update-templates -silent 2>/dev/null || true

# ── Python dependencies (includes arjun for FUZZ_PARAM) ──────
COPY workers/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt arjun

# ── Source (includes wordlists/ — DirFuzzWorker reads /app/wordlists/common.txt) ──
COPY workers/ .

EXPOSE 8000
